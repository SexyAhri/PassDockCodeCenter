# PassDock production env for the single-node SQLite deployment.
# Copy this file to ./passdock.env before running:
# docker compose -f passdock-docker-compose.sqlite.production.yml up -d --build

APP_NAME=PassDock
APP_ENV=production
APP_PORT=8080
APP_BASE_URL=https://passdock.example.com
APP_TIMEZONE=Asia/Shanghai
APP_LOG_LEVEL=info

# Keep reference data enabled for first boot so payment channels, products,
# providers, and strategies are created automatically. Demo orders should stay off.
BOOTSTRAP_REFERENCE_DATA=true
SEED_SAMPLE_BUSINESS_DATA=false

DB_DRIVER=sqlite
SQLITE_PATH=/app/data/passdock.db
POSTGRES_DSN=

SESSION_SECRET=replace_with_32_plus_random_chars
ADMIN_BEARER_TOKEN=
INTERNAL_SIGN_KEY=passdock-system
INTERNAL_SIGN_SECRET=replace_with_32_plus_random_chars

TELEGRAM_ENABLED=true
TELEGRAM_BOT_KEY=default
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_webhook_secret
# Leave TELEGRAM_WEBHOOK_URL empty to use:
# APP_BASE_URL + /api/v1/bots/default/telegram/webhook
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_IP_ADDRESS=
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
TELEGRAM_BOT_USERNAME=passdock_bot

STORAGE_TYPE=local
STORAGE_LOCAL_PATH=/app/storage
STORAGE_PUBLIC_PATH=/uploads
UPLOAD_MAX_FILE_SIZE_MB=8
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

ORDER_EXPIRE_MINUTES=30
PAYMENT_REVIEW_TIMEOUT_MINUTES=60
ORDER_SWEEP_INTERVAL_SECONDS=30
ASYNC_CONCURRENCY=10
ASYNC_POLL_INTERVAL_SECONDS=10
DELIVERY_RETRY_MAX_RETRIES=2
DELIVERY_RETRY_DELAY_SECONDS=60

# PassDock does not ship a native OKX wallet scanner in this repo.
# This template assumes you use the bundled watcher sidecar from Dockerfile.okxwatcher.
OKX_WATCHER_ENABLED=true
OKX_WATCHER_API_URL=http://okx-watcher:8090/api/scan
OKX_WATCHER_API_TOKEN=replace_with_okx_adapter_token
OKX_WATCHER_TIMEOUT_MS=10000
OKX_WATCHER_INTERVAL_SECONDS=60
OKX_WATCHER_BATCH_SIZE=50

# Bundled OKX watcher adapter.
# Current implementation watches TRON mainnet USDT (TRC20) inbound transfers.
OKX_ADAPTER_PORT=8090
OKX_ADAPTER_CHAIN=tron
OKX_ADAPTER_RECEIVE_ADDRESS=replace_with_your_tron_receive_address
OKX_ADAPTER_TOKEN_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
OKX_ADAPTER_TRONGRID_BASE_URL=https://api.trongrid.io
OKX_ADAPTER_TRONGRID_API_KEY=replace_with_trongrid_api_key
OKX_ADAPTER_SCAN_LIMIT=200
OKX_ADAPTER_MAX_PAGES=3
OKX_ADAPTER_LOOKBACK_MINUTES=180
OKX_ADAPTER_TIME_SKEW_SECONDS=300
OKX_ADAPTER_AMOUNT_TOLERANCE=0.000001

# Bundled new-api adapter.
# PassDock talks to the adapter over the compose network, and the adapter then calls your real new-api instance.
NEW_API_ADAPTER_PORT=8070
NEW_API_ADAPTER_STORE_PATH=/app/data/newapi-adapter-store.json
NEW_API_UPSTREAM_BASE_URL=https://new-api.example.com
NEW_API_UPSTREAM_ACCESS_TOKEN=replace_with_newapi_access_token
NEW_API_UPSTREAM_USER_ID=1
NEW_API_UPSTREAM_DEFAULT_RECHARGE_QUOTA=500000
NEW_API_UPSTREAM_SUBSCRIPTION_GROUP=default
NEW_API_UPSTREAM_SUBSCRIPTION_MODEL_LIMITS=
NEW_API_UPSTREAM_SUBSCRIPTION_UNLIMITED_QUOTA=true

# In production, bootstrap validation checks both new_api_prod and new_api_staging.
# This template points both providers to the bundled adapter so startup validation can pass.
NEW_API_PROD_BASE_URL=http://new-api-adapter:8070
NEW_API_PROD_KEY_ID=passdock-prod
NEW_API_PROD_SECRET=replace_with_new_api_prod_secret
NEW_API_PROD_TIMEOUT_MS=10000
NEW_API_PROD_RETRY_TIMES=2
NEW_API_STAGING_BASE_URL=http://new-api-adapter:8070
NEW_API_STAGING_KEY_ID=passdock-staging
NEW_API_STAGING_SECRET=replace_with_new_api_staging_secret
NEW_API_STAGING_TIMEOUT_MS=8000
NEW_API_STAGING_RETRY_TIMES=1

CORS_ALLOW_ORIGINS=https://passdock.example.com
