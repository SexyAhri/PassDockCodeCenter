FROM golang:1.26-alpine AS builder

WORKDIR /src/apps/okxwatcher

COPY apps/okxwatcher/go.mod ./
RUN go mod download

COPY apps/okxwatcher/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/okxwatcher ./cmd/okxwatcher

FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /out/okxwatcher /app/okxwatcher

EXPOSE 8090

ENTRYPOINT ["/app/okxwatcher"]
