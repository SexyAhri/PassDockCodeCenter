FROM golang:1.26-alpine AS builder

WORKDIR /src/apps/newapiadapter

COPY apps/newapiadapter/go.mod ./
RUN go mod download

COPY apps/newapiadapter/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/newapiadapter ./cmd/newapiadapter

FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

RUN mkdir -p /app/data

COPY --from=builder /out/newapiadapter /app/newapiadapter

EXPOSE 8070

ENTRYPOINT ["/app/newapiadapter"]
