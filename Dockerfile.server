FROM golang:1.26-alpine AS builder

WORKDIR /src/apps/server

COPY apps/server/go.mod apps/server/go.sum ./
RUN go mod download

COPY apps/server/ ./

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/passdock ./cmd/passdock

FROM alpine:3.21

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

RUN mkdir -p /app/data /app/storage

COPY --from=builder /out/passdock /app/passdock

EXPOSE 8080

ENTRYPOINT ["/app/passdock"]
