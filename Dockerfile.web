FROM node:22-alpine AS builder

WORKDIR /src/apps/web

ARG VITE_API_BASE_URL=
ARG VITE_LOCAL_DEMO_MODE=false
ARG VITE_ADMIN_BEARER_TOKEN=

COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm ci

COPY apps/web/ ./

ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
ENV VITE_LOCAL_DEMO_MODE=${VITE_LOCAL_DEMO_MODE}
ENV VITE_ADMIN_BEARER_TOKEN=${VITE_ADMIN_BEARER_TOKEN}

RUN npm run build

FROM nginx:1.27-alpine

COPY deploy/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /src/apps/web/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
