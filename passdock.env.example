# PassDock 后端环境变量示例
# 部署前请复制为 .env 或 passdock.env，并替换所有占位值。

APP_NAME=PassDock
APP_ENV=production
APP_PORT=8080
APP_BASE_URL=https://passdock.example.com
APP_TIMEZONE=Asia/Shanghai
APP_LOG_LEVEL=info

# 启动期种子数据控制
# - BOOTSTRAP_REFERENCE_DATA：初始化管理员、运行时设置、支付通道、商品、策略、Provider 等参考数据
# - SEED_SAMPLE_BUSINESS_DATA：初始化演示订单、支付凭证、工单、退款示例等业务演示数据
# 默认行为：
# - development / test：参考数据 + 演示业务数据
# - staging / production：仅参考数据
BOOTSTRAP_REFERENCE_DATA=
SEED_SAMPLE_BUSINESS_DATA=

# 数据库
# 可选值：sqlite / postgres
DB_DRIVER=sqlite
SQLITE_PATH=./data/passdock.db
POSTGRES_DSN=host=postgres port=5432 user=passdock password=replace_me dbname=passdock sslmode=disable TimeZone=Asia/Shanghai

# 认证
SESSION_SECRET=replace_with_long_random_secret
ADMIN_BEARER_TOKEN=

# 内部接口启动密钥
# 当数据库中没有同名 internal client key 时，使用这里的引导密钥
INTERNAL_SIGN_KEY=passdock-system
INTERNAL_SIGN_SECRET=replace_with_long_random_secret

# Telegram 启动配置
# 数据库中的同 bot_key 配置会覆盖这里的默认配置
# 官方 Bot API 对应关系：
# - TELEGRAM_BOT_TOKEN -> /bot<token>/setWebhook、getFile、sendMessage、sendPhoto、sendDocument 使用的机器人 Token
# - TELEGRAM_WEBHOOK_URL -> setWebhook.url
# - TELEGRAM_WEBHOOK_SECRET -> setWebhook.secret_token，Telegram 会通过 X-Telegram-Bot-Api-Secret-Token 回传
# - TELEGRAM_WEBHOOK_IP_ADDRESS -> setWebhook.ip_address
# - TELEGRAM_WEBHOOK_ALLOWED_UPDATES -> setWebhook.allowed_updates
# - TELEGRAM_WEBHOOK_MAX_CONNECTIONS -> setWebhook.max_connections
# - TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES -> setWebhook.drop_pending_updates
TELEGRAM_ENABLED=true
TELEGRAM_BOT_KEY=default
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_webhook_secret
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_IP_ADDRESS=
TELEGRAM_WEBHOOK_ALLOWED_UPDATES=message,callback_query
TELEGRAM_WEBHOOK_MAX_CONNECTIONS=40
TELEGRAM_WEBHOOK_DROP_PENDING_UPDATES=false
TELEGRAM_BOT_USERNAME=passdock_bot

# 上传与对象存储
# 可选值：local / minio
# MinIO 是对象存储，不是 OKX 或其他加密支付接口
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage
STORAGE_PUBLIC_PATH=/uploads
UPLOAD_MAX_FILE_SIZE_MB=8
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace_me
MINIO_SECRET_KEY=replace_me
MINIO_BUCKET=passdock
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# 运行时配置
ORDER_EXPIRE_MINUTES=30
PAYMENT_REVIEW_TIMEOUT_MINUTES=60
ORDER_SWEEP_INTERVAL_SECONDS=30
ASYNC_CONCURRENCY=10
ASYNC_POLL_INTERVAL_SECONDS=10
DELIVERY_RETRY_MAX_RETRIES=2
DELIVERY_RETRY_DELAY_SECONDS=60
OKX_WATCHER_ENABLED=false
OKX_WATCHER_INTERVAL_SECONDS=60
OKX_WATCHER_BATCH_SIZE=50

# OKX 扫单适配器
# PassDock 会定时轮询此地址，并复用 /internal/v1/payments/onchain/confirm 的内部确认逻辑
# 请求体示意：
# {
#   "payment_method": "okx_usdt",
#   "channel_key": "okx_usdt_watch",
#   "items": [
#     {
#       "order_no": "PD-240412-1001",
#       "amount": "5.49",
#       "currency": "USDT",
#       "buyer_ref": "web:buyer",
#       "created_at": "2026-04-12T10:18:00Z",
#       "expire_at": "2026-04-12T10:48:00Z"
#     }
#   ]
# }
# 响应体示意：
# {
#   "items": [
#     {
#       "order_no": "PD-240412-1001",
#       "status": "matched",
#       "amount": "5.49",
#       "currency": "USDT",
#       "chain_tx_hash": "0x...",
#       "payer_account": "0x...",
#       "third_party_txn_no": "",
#       "note": "optional adapter note"
#     }
#   ]
# }
OKX_WATCHER_API_URL=
OKX_WATCHER_API_TOKEN=
OKX_WATCHER_TIMEOUT_MS=10000

# new-api 内部适配器引导配置
# 当设置这些变量时，启动种子会将其写入 new_api_prod / new_api_staging Provider
# 在 staging / production 中，如果 NEW_API_*_BASE_URL 为空，则会保留 mock:// 引导目标，
# 并在 Provider 校验阶段直接阻止上线
NEW_API_PROD_BASE_URL=
NEW_API_PROD_KEY_ID=
NEW_API_PROD_SECRET=
NEW_API_PROD_TIMEOUT_MS=10000
NEW_API_PROD_RETRY_TIMES=2
NEW_API_STAGING_BASE_URL=
NEW_API_STAGING_KEY_ID=
NEW_API_STAGING_SECRET=
NEW_API_STAGING_TIMEOUT_MS=8000
NEW_API_STAGING_RETRY_TIMES=1

# CORS
CORS_ALLOW_ORIGINS=https://passdock.example.com
